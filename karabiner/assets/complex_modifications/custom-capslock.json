{
  "title": "Change caps_lock to Esc and Control",
  "rules": [
    {
      "description": "Post Esc if Caps is tapped, Control if held",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "is_built_in_keyboard": true
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
