{
	"title": "Left Option Key → Hyper Key (⌃⌥⇧⌘)",
	"rules": [
		{
			"description": "Left Option Key → Hyper Key (⌃⌥⇧⌘)",
			"manipulators": [
				{
					"from": {
						"key_code": "left_option",
						"modifiers": {
							"optional": ["any"]
						}
					},
					"to": [
						{
							"key_code": "right_shift",
							"modifiers": [
								"right_command",
								"left_control",
								"right_option"
							]
						}
					],
					"type": "basic"
				}
			]
		}
	]
}
